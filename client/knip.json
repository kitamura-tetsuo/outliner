{
    "$schema": "https://unpkg.com/knip@latest/schema.json",
    // Add .svelte to entry points
    "entry": [
        "src/index.ts", // Existing entries
        "src/routes/**/*.svelte" // Include SvelteKit pages as entry points
    ],
    // Include .svelte alongside .ts/.js for analysis across the project
    "project": [
        "src/**/*.{ts,js,svelte}"
    ],
    // (Optional) Check exports of entry files themselves
    "includeEntryExports": true
}
