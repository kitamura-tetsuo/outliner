{
  "name": "functions",
  "description": "Firebase Cloud Functions for Outliner",
  "scripts": {
    "lint": "eslint .",
    "serve": "firebase emulators:start --only auth,firestore,functions,hosting --project demo-test",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "build": "echo 'No build step required for JavaScript functions'",
    "debug": "firebase --debug emulators:start --inspect-functions=9229 --only auth,firestore,functions,hosting --project demo-test",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.60.0",
    "@sentry/node": "^10.47.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "file-type": "^22.0.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "axios": "^1.15.0",
    "eslint": "^10.2.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "firebase-functions-test": "^3.1.0",
    "jest": "^30.3.0"
  },
  "private": true
}
